NODE_ENV=production
PORT=3000
PUBLIC_URL=https://your-domain.com
DATABASE_URL=postgres://qbwc:pass@localhost:5432/qbwc_bridge?sslmode=require
# The full webhook URL n8n gives you when you activate the workflow. n8n
# generates a UUID path automatically; copy it from the n8n workflow page
# after activating. The UUID makes the endpoint unguessable, so this is
# the only auth the bridge->n8n channel needs.
N8N_WEBHOOK_URL=https://n8n.your-domain.com/webhook/00000000-0000-0000-0000-000000000000
SESSION_SECRET=change_me_to_a_32_character_random_string
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
ADMIN_RATE_LIMIT_MAX=30
MAX_BODY_SIZE=1mb
LOG_LEVEL=info
READ_ONLY=false
ADMIN_API_KEY=change_me_to_a_32_character_random_string
# TRUST_PROXY=1
