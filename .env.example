NODE_ENV=development
PORT=3000
PUBLIC_URL=https://your-domain.com
DATABASE_URL=postgres://user:pass@localhost:5432/qbwc_bridge
N8N_WEBHOOK_URL=http://localhost:5678/webhook/qbwc-events
N8N_WEBHOOK_SECRET=change_me_in_production
SESSION_SECRET=change_me_to_a_32_character_random_string
BCRYPT_ROUNDS=12
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
MAX_BODY_SIZE=1mb
LOG_LEVEL=info
